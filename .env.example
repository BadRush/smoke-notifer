# ╔══════════════════════════════════════════════════════════════════╗
# ║           smoke-notifier — Environment Variables               ║
# ║  Copy file ini ke .env lalu edit sesuai kebutuhan              ║
# ║  JANGAN commit file .env ke git!                               ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Telegram Bot (WAJIB) ─────────────────────────────────────────
# Dapatkan dari @BotFather di Telegram
SMOKE_TG_TOKEN=your_bot_token_here
SMOKE_TG_CHAT_ID=your_chat_id_here

# ─── Telegram Opsional ────────────────────────────────────────────
# Thread/Topic ID untuk grup dengan Topics enabled
# Cara dapat: buka topic di Telegram Desktop/Web → lihat URL terakhir
# SMOKE_TG_THREAD_ID=123

# ─── SmokePing Paths ──────────────────────────────────────────────
# Override path dari config.yaml jika diperlukan
# SMOKE_RRD_BASE_PATH=/var/lib/smokeping

# ─── Monitoring Settings ──────────────────────────────────────────
# Override interval monitoring (detik)
# SMOKE_CHECK_INTERVAL=60

# ─── File Paths ───────────────────────────────────────────────────
# SMOKE_STATE_FILE=/opt/smoke-notifier/state.json
# SMOKE_LOG_FILE=/opt/smoke-notifier/smoke-notifier.log
# SMOKE_GRAPH_TEMP_DIR=/tmp/smoke-notifier

# ─── Graph Settings ──────────────────────────────────────────────
# SMOKE_GRAPH_ENABLED=true
# SMOKE_GRAPH_DURATION=3h
# SMOKE_GRAPH_WIDTH=800
# SMOKE_GRAPH_HEIGHT=250

# ─── Logging ──────────────────────────────────────────────────────
# SMOKE_LOG_MAX_SIZE_MB=50
# SMOKE_LOG_BACKUP_COUNT=3

# ─── Heartbeat ────────────────────────────────────────────────────
# SMOKE_HEARTBEAT_ENABLED=true
# SMOKE_HEARTBEAT_TIME=07:00
